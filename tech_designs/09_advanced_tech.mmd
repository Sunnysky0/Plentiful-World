graph TD
    %% Advanced Technology Tech Tree - Plentiful World Mod
    %% Theme: 1936-1956+ (HOI4 Style with Cyberpunk 2077 / 2046 Limit)

    %% ==========================================
    %% 1. 电子学 (Electronics)
    %% ==========================================

    %% 战场通讯与雷达 (Comms & Radar)
    subgraph Comms [战场通讯与雷达]
        direction TB
        Com1["1936 基础战场通讯<br/>无线电"] --> Com2["1939 改进型通讯系统<br/>调频电台"]
        Com2 --> Com3["1942 先进通讯网络<br/>微波中继"]
        Com3 --> Com4["1945 现代数据链<br/>C3I系统"]
        Com4 --> Com5["1949 卫星通讯终端<br/>全球覆盖"]
        
        Rad1["1938 基础雷达站<br/>早期预警"] --> Rad2["1941 改进型分米波雷达<br/>火控引导"]
        Rad2 --> Rad3["1944 先进厘米波雷达<br/>低空补盲"]
        Rad3 --> Rad4["1948 现代相控阵雷达<br/>多目标追踪"]
        Rad4 --> Rad5["1953 实验型量子雷达<br/>反隐身探测"]
        
        Com1 -.-> Rad1
    end

    %% 计算机技术 (Computing - Electronic/Quantum/Wetware)
    subgraph Computing [计算技术]
        direction TB
        Comp1["1936 高级集成电路<br/>科研速度+"] --> Comp2["1939 个人计算机升级"]
        Comp2 --> Comp3["1942 改进型 7nm 制程<br/>小型化"]
        Comp3 --> Comp4["1946 先进型 3nm 制程<br/>微处理器"]
        
        %% 分支：量子 vs 湿件
        Comp4 --> Quant1["1950 实验型量子计算机<br/>超高速解密"]
        Comp4 --> Wet1["1950 实验型湿件计算机<br/>生物脑组织 模糊运算"]
        
        Quant1 --> Quant2["1955 实用化量子网络<br/>绝对加密"]
        Wet1 --> Wet2["1955 神经生物处理器<br/>直觉AI"]
    end

    %% ==========================================
    %% 2. 物理学 (Physics)
    %% ==========================================

    subgraph Physics [物理学研究]
        direction TB
        Phy1["1936 基础原子研究<br/>理论物理"] --> Phy2["1940 核裂变实验<br/>原子弹前置"]
        Phy2 --> Phy3["1944 反应堆小型化<br/>核动力引擎"]
        Phy3 --> Phy4["1949 冷聚变理论<br/>高能电池"]
        Phy4 --> Phy5["1954 基础反重力研究<br/>悬浮技术原型"]
        
        %% 激光/能量武器分支
        Phy2 -.-> Laser1["1943 基础激光原理<br/>红宝石激光"]
        Laser1 --> Laser2["1948 战术高能激光<br/>近防拦截"]
        Laser2 --> Laser3["1953 武器化粒子束<br/>穿透护盾"]
    end

    %% ==========================================
    %% 3. 生物学 (Biology)
    %% ==========================================

    subgraph Biology [生物工程]
        direction TB
        Bio1["1936 基础基因理论<br/>优生学"] --> Bio2["1939 激素强化技术<br/>超级士兵血清I型"]
        Bio2 --> Bio3["1943 快速克隆技术<br/>器官再生 人力补充"]
        Bio3 --> Bio4["1947 神经义体植入<br/>赛博格原型"]
        Bio4 --> Bio5["1952 基因编辑婴儿<br/>完美人类计划"]
        
        %% 欲望/结晶生物学 (Mod Flavor)
        Bio1 -.-> DesBio1["1938 费洛蒙提取技术<br/>资源产出+"]
        DesBio1 --> DesBio2["1942 活体结晶共生<br/>能量直接吸收"]
        DesBio2 --> DesBio3["1948 群体意识网络<br/>蜂巢思维"]
    end

    %% ==========================================
    %% 4. 人工智能 (Artificial Intelligence)
    %% ==========================================

    subgraph AI [人工智能]
        direction TB
        AI1["1940 基础自动化逻辑<br/>专家系统"] --> AI2["1944 弱人工智能<br/>战术辅助"]
        AI2 --> AI3["1948 神经网络算法<br/>深度学习"]
        AI3 --> AI4["1952 强人工智能原型<br/>自我意识觉醒"]
        AI4 --> AI5["1956 数字人格模拟<br/>永生雏形"]
    end

    %% ==========================================
    %% 5. 物流学 (Logistics)
    %% ==========================================

    subgraph Logistics [先进物流]
        direction TB
        Log1["1936 基础运筹学<br/>补给效率+"] --> Log2["1940 集装箱化物流<br/>港口吞吐+"]
        Log2 --> Log3["1944 射频识别(RFID)管理<br/>库存精准化"]
        Log3 --> Log4["1949 全自动仓储系统<br/>无人搬运"]
        Log4 --> Log5["1954 亚轨道快递投送<br/>全球极速达"]
    end

    %% ==========================================
    %% 连接关系 (Links)
    %% ==========================================

    %% 电子学 -> AI
    Comp4 --> AI1
    Quant1 -.-> AI4
    
    %% 物理 -> 电子
    Phy3 -.-> Comp4
    
    %% 生物 -> AI (湿件)
    Bio4 -.-> Wet1
    
    %% 电子 -> 物流
    Com4 -.-> Log3

